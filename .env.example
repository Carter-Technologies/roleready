# Frontend (Vite — safe to expose in browser)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Server only (Vercel → Project → Environment Variables)
OPENROUTER_API_KEY=your-openrouter-key

# Local DB backup (scripts/backup-db.sh) — never commit real values
# If password contains *, #, @, etc., use separate vars with SINGLE QUOTES (not a URI):
PGHOST=aws-0-[region].pooler.supabase.com
PGPORT=5432
PGUSER=postgres.[ref]
PGDATABASE=postgres
PGPASSWORD='your-password-here'
