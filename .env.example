# Frontend (Vite — safe to expose in browser)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Server only (Vercel → Project → Environment Variables)
OPENROUTER_API_KEY=your-openrouter-key

# Billing / paywall (server only — never VITE_)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Price ID (price_...), NOT the product ID (prod_...)
STRIPE_PRICE_ID_PRO_MONTHLY=price_...
# Optional: canonical app URL for Stripe redirects
VITE_APP_URL=https://www.kigho.com

# Coming soon: production is locked by default. Set when ready to launch:
# VITE_SITE_LIVE=true
# SITE_LIVE=true
# Optional: force lock in local dev for testing — VITE_SITE_LOCKED=true

# Local DB backup (scripts/backup-db.sh) — never commit real values
# If password contains *, #, @, etc., use separate vars with SINGLE QUOTES (not a URI):
PGHOST=aws-0-[region].pooler.supabase.com
PGPORT=5432
PGUSER=postgres.[ref]
PGDATABASE=postgres
PGPASSWORD='your-password-here'
