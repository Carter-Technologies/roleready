# Frontend (Vite — safe to expose in browser)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Server only (Vercel → Project → Environment Variables)
OPENROUTER_API_KEY=your-openrouter-key

# Local DB backup only (scripts/backup-db.sh) — never commit real values
# Supabase → Settings → Database → Connection string → URI
SUPABASE_DB_URL=postgresql://postgres.[ref]:[PASSWORD]@db.[ref].supabase.co:5432/postgres
