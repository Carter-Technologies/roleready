# Local overrides — copy to .env.local (gitignored). Vite loads this on top of .env.
#
# cp .env.local.example .env.local

# Auth password-reset and Stripe redirects should use localhost in dev
VITE_APP_URL=http://localhost:5173

# Recommended: use Stripe TEST keys locally (override live keys from .env)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PRICE_ID_PRO_MONTHLY=price_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Dev is unlocked by default. Only set if you want to test coming-soon locally:
# VITE_SITE_LOCKED=true
